<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="mauikit.navigation.core.Views.MauiPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:interfaces="clr-namespace:mauikit.navigation.core.Interfaces"
    x:Name="MauiPageName"
    x:DataType="interfaces:IMauiViewModel">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference MauiPageName}, x:DataType=ContentPage}"
            Command="{Binding AppearingCommand}"
            EventName="Appearing" />
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference MauiPageName}, x:DataType=ContentPage}"
            Command="{Binding DisappearingCommand}"
            EventName="Disappearing" />
    </ContentPage.Behaviors>
</ContentPage>  
<?xml version="1.0" encoding="utf-8"?>

<views:MauiPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:mauikit.navigation.core.Views;assembly=mauikit.navigation.core"
    xmlns:main="clr-namespace:mauikit.navigation.sample.Features.Main"
    xmlns:main1="clr-namespace:mauikit.navigation.sample.Features.Main"
    Shell.PresentationMode="Animated"
    x:DataType="main1:NewViewModel"
    x:Class="mauikit.navigation.sample.Features.Main.NewPage">

    <VerticalStackLayout
        HorizontalOptions="Center"
        VerticalOptions="Center"
        >
        
    <Label
        Text="i'm a page"/>
    <Label>
        <Label.FormattedText>
            <FormattedString>
                <Span Text="Parameter received: "/>
                <Span Text="{Binding DataReceived}"/>
            </FormattedString>
        </Label.FormattedText>
    </Label>
    </VerticalStackLayout>
    
</views:MauiPage>
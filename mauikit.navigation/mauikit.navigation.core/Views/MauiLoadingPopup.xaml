<?xml version="1.0" encoding="utf-8" ?>

<views:MauiPopup
    x:Class="mauikit.navigation.core.Views.MauiLoadingPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:mauikit.navigation.core.Views"
    xmlns:classes="clr-namespace:mauikit.navigation.core.Classes"
    x:Name="LoadingMauiPopupName"
    ControlTemplate="{StaticResource LoadingPopupTemplate}">

    <views:MauiPopup.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="LoadingPopupTemplate" x:DataType="classes:MauiPopupViewModel">
                <Grid>
                    <ContentPresenter />

                    <Grid
                        x:Name="LoadingPopupOverlay"
                        BackgroundColor="#80000000"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding Source={x:Static RelativeBindingSource.TemplatedParent}, Path=BindingContext.IsBusy, x:DataType=classes:MauiPopupViewModel}"
                        VerticalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer />
                        </Grid.GestureRecognizers>

                        <ActivityIndicator
                            HorizontalOptions="Center"
                            IsRunning="True"
                            VerticalOptions="Center"
                            Color="{Binding x:DataType=views:MauiLoadingPopup, Source={x:Reference LoadingMauiPopupName}, Path=LoaderColor}" />
                    </Grid>
                </Grid>
            </ControlTemplate>
        </ResourceDictionary>
    </views:MauiPopup.Resources>
</views:MauiPopup>
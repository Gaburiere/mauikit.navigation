<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mauikit.navigation.sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mauikit.navigation.sample"
    xmlns:main="clr-namespace:mauikit.navigation.sample.Features.Main"
    xmlns:settings="clr-namespace:mauikit.navigation.sample.Features.Settings"
    FlyoutBehavior="Flyout"
    Title="mauikit.navigation.sample">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate main:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate settings:SettingsPage}"
        Route="Settings" />
</Shell>

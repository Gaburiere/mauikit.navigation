<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:interfaces="clr-namespace:mauikit.navigation.core.Interfaces"
    x:Class="mauikit.navigation.core.Views.MauiPopup"
    x:Name="MauiPopupName"
    x:DataType="interfaces:IMauiPopupViewModel">
    
    <toolkit:Popup.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference MauiPopupName}, x:DataType=toolkit:Popup}"
            Command="{Binding OpenedCommand}"
            EventName="Opened" />
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference MauiPopupName}, x:DataType=toolkit:Popup}"
            Command="{Binding ClosedCommand}"
            EventName="Closed" />
    </toolkit:Popup.Behaviors>
</toolkit:Popup>